{
  "name": "@successible/cleanslate",
  "repository": "https://github.com/successible/cleanslate.git",
  "author": "Successible",
  "license": "BUSL-1.1",
  "private": true,
  "engines": {
    "node": "18"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "sort"
    ],
    "extends": [
      "eslint:recommended",
      "next/core-web-vitals",
      "plugin:@typescript-eslint/recommended",
      "plugin:sort/recommended"
    ],
    "rules": {
      "react/no-unknown-property": [
        "error",
        {
          "ignore": [
            "css"
          ]
        }
      ],
      "@typescript-eslint/no-explicit-any": "off",
      "@typescript-eslint/no-empty-function": "off",
      "@typescript-eslint/ban-ts-comment": "off",
      "@next/next/no-html-link-for-pages": "off"
    }
  },
  "scripts": {
    "build": "pnpm install && cd src && next build && next export -o out && npx workbox generateSW workbox-config.js && cp -r out ../build && cd .. && pnpm run migrate",
    "dev": "bash start.sh",
    "proxy": "bash proxy.sh",
    "lint": "bash lint.sh --format",
    "migrate": "node migrate.js;",
    "test": "jest"
  },
  "dependencies": {
    "@babel/core": "7.20.2",
    "@emotion/react": "11.10.5",
    "@honeybadger-io/js": "4.7.1",
    "@honeybadger-io/react": "4.7.2",
    "@maslick/koder": "1.3.2",
    "@typed/curry": "1.0.1",
    "@types/clone-deep": "4.0.1",
    "@types/jest": "29.2.3",
    "@types/js-cookie": "3.0.2",
    "@types/ms": "0.7.31",
    "@types/node": "18.11.9",
    "@types/react": "18.0.25",
    "@types/throttle-debounce": "5.0.0",
    "@types/traverse": "0.6.32",
    "@types/ua-parser-js": "0.7.36",
    "@typescript-eslint/eslint-plugin": "5.44.0",
    "@typescript-eslint/parser": "5.44.0",
    "axios": "1.1.3",
    "chagall": "1.13.0",
    "clone-deep": "4.0.1",
    "compare-versions": "5.0.1",
    "csv-loader": "3.0.5",
    "csv-parser": "3.0.0",
    "dayjs": "1.11.6",
    "deepmerge": "4.2.2",
    "dot-prop-immutable": "2.1.1",
    "dotenv": "16.0.3",
    "eslint": "8.28.0",
    "eslint-config-next": "13.0.4",
    "eslint-plugin-sort": "2.4.0",
    "firebase": "9.14.0",
    "focus-trap-react": "10.0.1",
    "graphql": "16.6.0",
    "hasura-cli": "2.15.1",
    "jest": "29.3.1",
    "js-cookie": "3.0.1",
    "just-safe-get": "4.1.1",
    "ms": "2.1.3",
    "next": "13.0.4",
    "pg": "8.8.0",
    "pg-format": "1.0.4",
    "prettier": "2.7.1",
    "prop-types": "15.8.1",
    "quick-score": "0.2.0",
    "react": "18.2.0",
    "react-div-100vh": "0.7.0",
    "react-dom": "18.2.0",
    "react-icons": "4.6.0",
    "react-markdown": "8.0.3",
    "react-switch": "7.0.0",
    "sass": "1.56.1",
    "storeon": "3.1.5",
    "subscriptions-transport-ws": "0.11.0",
    "throttle-debounce": "5.0.0",
    "traverse": "0.6.7",
    "ts-jest": "29.0.3",
    "typescript": "4.9.3",
    "ua-parser-js": "1.0.32",
    "uuid-random": "1.3.2",
    "webpack": "5.75.0",
    "workbox-cli": "6.5.4"
  }
}
